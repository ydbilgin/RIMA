# Local state — never commit
.claude/nlm_sync_state.txt
.claude/nlm_last_sync.txt
.mcp.json

# Secrets — auth cookies, tweet caches
STAGING/cookies_*.txt
STAGING/*_cookies.txt
STAGING/boona_video.mp4
STAGING/boona_frames/
STAGING/boona_tweet.info.json
STAGING/boona_thread.json

# Unity generated — never commit
Library/
Temp/
Logs/
obj/
Build/
Builds/

# IDE generated — Unity regenerates these
*.csproj
*.sln
*.slnx
.vs/

# Graphify tool output
.graphify_incremental.json
.graphify_python
.graphifyignore
graphify-out/

# User-local settings
UserSettings/

# External tools
Pixellab extension/

# Obsidian — workspace state (kişisel, commit edilmez)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
_attachments/

# STAGING: heavy / ephemeral subdirectories
STAGING/discord_pixellab/
STAGING/yt_videos/
STAGING/yt_frames/

# ARCHIVE: research raw data (already committed once as checkpoint)
ARCHIVE/RESEARCH_RAW/

# Claude internal
.claude/scheduled_tasks.lock
.playwright-cli/

# Python tooling
__pycache__/
*.pyc

# Package manager backups
Packages/*.bak

# Local history backups
CODEX_DONE_history_backup.md

# Binary assets — default-ignored; USED game assets are tracked (audit 2026-06-07)
# Policy: Resources/** + Assets/Audio/** auto-tracked; other used assets force-added
# via STAGING/ASSET_USAGE_AUDIT (GUID cross-reference). Archives/unused stay local.
*.png
!Assets/Resources/**/*.png
!Assets/Audio/**/*.wav
!Assets/Audio/**/*.ogg
!Assets/Audio/**/*.mp3
!Assets/Resources/**/*.wav
!Assets/Resources/**/*.ogg
!Assets/Resources/**/*.mp3
# Screenshot .meta — PNGs above are ignored; don't track orphan dev-screenshot metas
Assets/Screenshots/*.png.meta
*.jpg
*.jpeg
*.gif
*.bmp
*.tga
*.psd
*.mp4
*.mov
*.webm
*.wav
*.mp3
*.ogg
*.fbx
*.obj
*.blend

# Context Mode (MCP output sandbox)
.context-mode/

# OS
.DS_Store
Thumbs.db
desktop.ini
_backups/

# Secrets — recursive cookie/credential captures (top-level rule above missed subdirs)
STAGING/**/cookies_*.txt
STAGING/**/*_cookies.txt

# Agent dispatch artifacts — runtime I/O, never commit
CODEX_DONE*.md
CODEX_TASK*.md
AGY_DONE*.md
AGY_TASK*.md
.agy_dispatch_state.json
.agy_dispatch_relaunch.log
.cx_dispatch_locks/
.cx_dispatch/
.ax_dispatch/
# Large re-extractable reference package dumps (keep the source zip in Downloads)
STAGING/_process/**/chatgpt_pkg_*/
*.tmp
*.tmp.*
tmp/

# Backup / archive-junk directories — local only
_backup_*/
_archive_root_junk*/
_archive_sprites_*~/
.antigravitycli/

# STAGING transient I/O & heavy archives — local only (2026-06-14)
STAGING/_archive/zips_*/
STAGING/_inbox/
STAGING/_outbox/
STAGING/unity_compile_*.log
# Orphan .meta for STAGING PNGs (the PNGs themselves are *.png-ignored)
STAGING/**/*.png.meta

# NLM notebook ID (private — repo disi)
.claude/nlm.local

