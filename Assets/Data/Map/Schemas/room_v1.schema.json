{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rima.map.room_layout.v1",
  "title": "RIMA Room Layout v1",
  "description": "JSON schema for a single room layout (loaded by RoomLoader to populate Tilemap + props + mobs + doors).",
  "type": "object",
  "required": ["schema_version", "room_id", "width", "height", "floor"],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Schema version for migration compatibility"
    },
    "room_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Stable unique id (e.g. 'act1_entry_hall')"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name shown in editor UI"
    },
    "act": {
      "type": "string",
      "enum": ["act1_shattered_keep", "act2_painted_garden", "act3_threadwound_athenaeum", "act4_rift_throne"],
      "description": "Act this room belongs to (controls theme defaults)"
    },
    "room_type": {
      "type": "string",
      "enum": ["spawn", "corridor_linear", "corridor_l", "combat_small", "combat_medium", "combat_large", "treasure", "shrine", "elite", "boss_intro", "boss_arena", "hidden", "atrium", "megaroom"],
      "description": "Functional type (drives gameplay logic: lock-on-enter, mob spawn rules, etc.)"
    },
    "width": {
      "type": "integer",
      "minimum": 8,
      "maximum": 64,
      "description": "Grid width in tile cells (1 cell = 1 unit = 64px)"
    },
    "height": {
      "type": "integer",
      "minimum": 8,
      "maximum": 48,
      "description": "Grid height in tile cells"
    },
    "shape": {
      "type": "object",
      "description": "Non-rectangular shape descriptor. Omit for default rectangular.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["rectangle", "l_shape", "t_shape", "alcove", "hex", "atrium_island"]
        },
        "alcoves": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["wall", "offset", "width", "depth"],
            "properties": {
              "wall": { "enum": ["north", "south", "east", "west"] },
              "offset": { "type": "integer", "minimum": 0 },
              "width": { "type": "integer", "minimum": 2 },
              "depth": { "type": "integer", "minimum": 2 }
            }
          }
        },
        "rects": {
          "type": "array",
          "description": "Multiple rect union for l_shape/t_shape",
          "items": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "integer" },
              "y": { "type": "integer" },
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          }
        },
        "inner_obstacle_rect": {
          "type": "object",
          "description": "Atrium center island (unwalkable but no wall)",
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" },
            "width": { "type": "integer" },
            "height": { "type": "integer" }
          }
        }
      }
    },
    "floor": {
      "type": "object",
      "description": "Floor material zones. Loader picks variant from MaterialVariantPool per cell.",
      "required": ["default_material"],
      "properties": {
        "default_material": {
          "type": "string",
          "enum": ["granite", "rubble", "walkway", "rift", "dirt", "stone", "wood", "water"],
          "description": "Fallback material for all cells not in zones"
        },
        "zones": {
          "type": "array",
          "description": "Material zones override default; later zones override earlier (z-order)",
          "items": {
            "type": "object",
            "required": ["material", "rect"],
            "properties": {
              "material": { "type": "string" },
              "rect": {
                "type": "object",
                "required": ["x", "y", "width", "height"],
                "properties": {
                  "x": { "type": "integer" },
                  "y": { "type": "integer" },
                  "width": { "type": "integer" },
                  "height": { "type": "integer" }
                }
              },
              "blend_edges": {
                "type": "boolean",
                "default": false,
                "description": "If true, edge cells use transition tile from style_images modular pack"
              }
            }
          }
        },
        "accents": {
          "type": "array",
          "description": "Single-cell accent placements (rift veins, decals)",
          "items": {
            "type": "object",
            "required": ["material", "x", "y"],
            "properties": {
              "material": { "type": "string" },
              "x": { "type": "integer" },
              "y": { "type": "integer" }
            }
          }
        }
      }
    },
    "walls": {
      "type": "array",
      "description": "Wall placements (GameObject prefabs per Karar #144 wall pipeline)",
      "items": {
        "type": "object",
        "required": ["prefab", "x", "y"],
        "properties": {
          "prefab": {
            "type": "string",
            "description": "Prefab id (resolved via WallPrefabRegistry SO). E.g. 'wall_straight_n', 'wall_corner_ne', 'archway_n'"
          },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "rotation": {
            "type": "integer",
            "enum": [0, 90, 180, 270],
            "default": 0
          },
          "variant_seed": {
            "type": "integer",
            "default": 0,
            "description": "Deterministic variant pick (0 = first, randomize via room_id hash)"
          }
        }
      }
    },
    "props": {
      "type": "array",
      "description": "Decoration props (columns, banners, urns, torches, debris)",
      "items": {
        "type": "object",
        "required": ["prefab", "x", "y"],
        "properties": {
          "prefab": { "type": "string" },
          "x": { "type": "number", "description": "Float allowed for off-grid prop placement" },
          "y": { "type": "number" },
          "rotation": { "type": "number", "default": 0 },
          "scale": { "type": "number", "default": 1.0 },
          "flip_x": { "type": "boolean", "default": false },
          "sorting_order_override": {
            "type": "integer",
            "description": "Override per Y-sort if non-standard"
          }
        }
      }
    },
    "mob_spawns": {
      "type": "array",
      "description": "Enemy spawn points + wave grouping",
      "items": {
        "type": "object",
        "required": ["mob_id", "x", "y"],
        "properties": {
          "mob_id": {
            "type": "string",
            "description": "MobDatabase id (e.g. 'rift_husk', 'shattered_knight')"
          },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "wave": {
            "type": "integer",
            "default": 1,
            "description": "Wave grouping (1 = spawn on room enter, 2+ = trigger after wave 1 cleared)"
          },
          "elite": {
            "type": "boolean",
            "default": false
          },
          "patrol_path": {
            "type": "array",
            "description": "Optional waypoint patrol",
            "items": {
              "type": "object",
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "doors": {
      "type": "array",
      "description": "Door triggers + connection targets (DoorTrigger compatible)",
      "items": {
        "type": "object",
        "required": ["direction", "x", "y", "target_room_id"],
        "properties": {
          "direction": { "enum": ["north", "south", "east", "west"] },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "target_room_id": {
            "type": "string",
            "description": "Target room id (must exist in MapManifest); empty if exits Act"
          },
          "target_spawn_point": {
            "type": "string",
            "default": "default",
            "description": "Spawn point id in target room (matches spawn_points entry)"
          },
          "locked_initial": {
            "type": "boolean",
            "default": false,
            "description": "Door starts locked (combat room — unlock on wave clear)"
          },
          "key_required": {
            "type": "string",
            "description": "Item id required to unlock (puzzle/lore gating)"
          }
        }
      }
    },
    "spawn_points": {
      "type": "array",
      "description": "Player spawn anchor points per door direction (where player appears when entering from a door)",
      "items": {
        "type": "object",
        "required": ["id", "x", "y"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Spawn id (e.g. 'default', 'from_north', 'from_south')"
          },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "camera_bounds": {
      "type": "object",
      "description": "Camera Y-clamp + X-clamp for this room (CameraFollow.bounds)",
      "properties": {
        "x_min": { "type": "number" },
        "x_max": { "type": "number" },
        "y_min": { "type": "number" },
        "y_max": { "type": "number" }
      }
    },
    "lighting": {
      "type": "object",
      "description": "URP 2D Light setup per room mood",
      "properties": {
        "global_color": {
          "type": "string",
          "description": "Hex color (e.g. '#3A3D42')"
        },
        "global_intensity": {
          "type": "number",
          "default": 1.0
        },
        "point_lights": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["x", "y", "color", "intensity"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "color": { "type": "string" },
              "intensity": { "type": "number" },
              "outer_radius": { "type": "number", "default": 4 },
              "flicker": { "type": "boolean", "default": false }
            }
          }
        }
      }
    },
    "audio": {
      "type": "object",
      "properties": {
        "music_track_id": {
          "type": "string",
          "description": "MusicDatabase id"
        },
        "ambient_loop_id": {
          "type": "string",
          "description": "AmbientLoop id (wind, drip, torch crackle)"
        },
        "music_state_on_combat": {
          "type": "string",
          "enum": ["intensify", "switch", "stay"],
          "default": "intensify"
        }
      }
    },
    "post_process": {
      "type": "object",
      "description": "Post-process volume per room (optional override)",
      "properties": {
        "profile_id": {
          "type": "string",
          "description": "PostProcessProfile asset id"
        }
      }
    },
    "narrative": {
      "type": "object",
      "description": "Optional story beats (lore note, NPC dialog trigger)",
      "properties": {
        "lore_note_id": {
          "type": "string"
        },
        "npc_spawn": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "npc_id": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "dialog_id": { "type": "string" }
            }
          }
        }
      }
    },
    "rewards": {
      "type": "object",
      "description": "Reward placements (chest, pickup)",
      "properties": {
        "chests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tier": { "enum": ["common", "rare", "epic", "legendary"] },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "key_required": { "type": "string" }
            }
          }
        },
        "pickups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pickup_id": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
